# ═══════════════════════════════════
# SmartTravel Qingyuan — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════

# ── Database (PostgreSQL) ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smarttravel?schema=public"

# ── Auth ──
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET"

# ── OAuth: WeChat Open Platform ──
# Register at https://open.weixin.qq.com
WECHAT_OAUTH_APP_ID=""
WECHAT_OAUTH_APP_SECRET=""

# ── OAuth: QQ Connect ──
# Register at https://connect.qq.com
QQ_APP_ID=""
QQ_APP_KEY=""

# ── SMS (Aliyun) ──
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# ── Email (Resend) ──
RESEND_API_KEY=""

# ── Payment: Alipay ──
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""

# ── Payment: WeChat Pay ──
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY_V3=""
WECHAT_SERIAL_NO=""
WECHAT_PRIVATE_KEY=""

# ── Payment: Stripe ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── File Storage (Aliyun OSS) ──
OSS_REGION=""
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""

# ── AI / LLM (OpenAI-compatible) ──
# 方案A (优先): timesniper.club (Claude/Grok 多模型网关)
OPENAI_API_KEY="sk-bcrobMjozPmAtSgP3Neo0AI9Q1QpAz2amyEerK1BHo93hjzM"
OPENAI_BASE_URL="https://timesniper.club/v1"
OPENAI_MODEL="gemini-3-pro-preview-thinking-128-fixed"
# 可用模型: claude-sonnet-4-7, claude-opus-4-6, grok-420-fast, grok-4
# 方案B: azya.top (Qwen3.5, 已验证可用)
# OPENAI_API_KEY="sk-94a95c4eed28c7663770ce91773cb3b063720da3"
# OPENAI_BASE_URL="https://ai.azya.top/v1"
# OPENAI_MODEL="qwen3.5"
# 方案C: iFlow API
# OPENAI_API_KEY="sk-2b60ebe3b0f790dd657851b231ea911e"
# OPENAI_BASE_URL="https://apis.iflow.cn/v1"
# OPENAI_MODEL="qwen3-vl-plus"

# ── AI / LLM (Anthropic Claude) ──
# Set ANTHROPIC_API_KEY to use Claude Sonnet / Opus
ANTHROPIC_API_KEY=""

# ── AI Image Generation (OpenAI-compatible endpoint) ──
# Separate API for image generation (e.g., Gemini image models via LemonAPI)
# If not set, falls back to OPENAI_API_KEY/BASE_URL
IMAGE_API_KEY="sk-2b60ebe3b0f790dd657851b231ea911e"
IMAGE_API_BASE_URL="https://apis.iflow.cn/v1"
IMAGE_API_MODEL="qwen3-vl-plus"
# Alternative image models: dall-e-3, gemini-2.5-flash-image
# Alternative models: [L]gemini-3-pro-image-preview, [L]gemini-3.1-flash-image-preview

# ── AI / LLM (Google Gemini - native API) ──
# Direct Google Gemini API (optional, used if GEMINI_API_KEY is set)
GEMINI_API_KEY=""

# ── Embedding Model (for semantic vector search) ──
EMBEDDING_MODEL="text-embedding-3-small"

# ── 高德地图 (Amap JS API) ──
NEXT_PUBLIC_AMAP_JS_KEY="07abd64d9031acf5c034108c7d824785"
NEXT_PUBLIC_AMAP_SECURITY_KEY="ef8f007d12233e9523b6aa165bdda504"

# ── App ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
