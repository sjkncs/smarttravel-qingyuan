# ═══════════════════════════════════
# SmartTravel Qingyuan — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════

# ── Database (PostgreSQL) ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smarttravel?schema=public"

# ── Auth ──
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET"

# ── OAuth: WeChat Open Platform ──
# Register at https://open.weixin.qq.com
WECHAT_OAUTH_APP_ID=""
WECHAT_OAUTH_APP_SECRET=""

# ── OAuth: QQ Connect ──
# Register at https://connect.qq.com
QQ_APP_ID=""
QQ_APP_KEY=""

# ── SMS (Aliyun) ──
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# ── Email (Resend) ──
RESEND_API_KEY=""

# ── Payment: Alipay ──
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""

# ── Payment: WeChat Pay ──
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY_V3=""
WECHAT_SERIAL_NO=""
WECHAT_PRIVATE_KEY=""

# ── Payment: Stripe ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── File Storage (Aliyun OSS) ──
OSS_REGION=""
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""

# ── AI / LLM (OpenAI-compatible) ──
# Supports OpenAI, DeepSeek, Moonshot, Zhipu, Qwen, etc.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
# Optional: higher quality models
# OPENAI_MODEL="gpt-4o"             # OpenAI GPT-4o
# OPENAI_MODEL="deepseek-chat"      # DeepSeek V3 (cost-effective)
# OPENAI_MODEL="moonshot-v1-8k"    # Moonshot Kimi

# ── AI / LLM (Anthropic Claude) ──
# Set ANTHROPIC_API_KEY to use Claude Sonnet / Opus
ANTHROPIC_API_KEY=""
# OPENAI_MODEL="claude-sonnet-4-5"  # Claude Sonnet 4.5 (recommended)
# OPENAI_MODEL="claude-opus-4-5"   # Claude Opus 4.5 (best quality)
# OPENAI_MODEL="claude-3-5-sonnet-20241022"  # Claude 3.5 Sonnet

# ── AI Image Generation (OpenAI-compatible endpoint) ──
# Separate API for image generation (e.g., Gemini image models via LemonAPI)
# If not set, falls back to OPENAI_API_KEY/BASE_URL
IMAGE_API_KEY=""
IMAGE_API_BASE_URL="https://new.lemonapi.site/v1"
IMAGE_API_MODEL="[L]gemini-2.5-flash-image"
# Alternative models: [L]gemini-3-pro-image-preview, [L]gemini-3.1-flash-image-preview

# ── AI / LLM (Google Gemini - native API) ──
# Direct Google Gemini API (optional, used if GEMINI_API_KEY is set)
GEMINI_API_KEY=""

# ── AI Content Moderation (DeepSeek) ──
# Dedicated DeepSeek API for content moderation (recommended)
# If not set, falls back to OPENAI_API_KEY/BASE_URL
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
# Alternative: use OPENAI_API_KEY with DeepSeek-compatible proxy
# DEEPSEEK_BASE_URL="https://your-proxy.com/v1"
# DEEPSEEK_MODEL="deepseek-chat"

# ── Amap (高德地图) Web Service ──
# Register at https://lbs.amap.com — 申请 Web服务 类型的 Key
AMAP_WEB_KEY=""
# JS API Key (for frontend map display, apply for "Web端(JS API)" type)
NEXT_PUBLIC_AMAP_JS_KEY=""
# Security code for JS API (optional, recommended for production)
NEXT_PUBLIC_AMAP_SECURITY_CODE=""

# ── Embedding Model (for semantic vector search) ──
EMBEDDING_MODEL="text-embedding-3-small"

# ── App ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
