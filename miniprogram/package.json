{
  "name": "smarttravel-qingyuan-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "智游清远微信小程序 — 基于 Taro + React 跨端开发",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "SmartTravel Qingyuan",
  "dependencies": {
    "@babel/runtime": "^7.27.1",
    "@tarojs/cli": "4.x",
    "@tarojs/components": "4.x",
    "@tarojs/helper": "4.x",
    "@tarojs/plugin-framework-react": "4.x",
    "@tarojs/plugin-platform-weapp": "4.x",
    "@tarojs/plugin-platform-h5": "4.x",
    "@tarojs/react": "4.x",
    "@tarojs/runtime": "4.x",
    "@tarojs/shared": "4.x",
    "@tarojs/taro": "4.x",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tarojs/plugin-html": "4.x"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@types/react": "^18.3.12",
    "babel-preset-taro": "4.x",
    "typescript": "~5.7.0",
    "sass": "^1.83.0"
  }
}
